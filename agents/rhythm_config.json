{
  "rhythms": {
    "stabilize": {
      "description": "Consolidation, crystallization, attractor merge. Field energy < 0.5.",
      "energy_threshold": 0.5,
      "behaviors": ["crystal_activation", "field_diffusion", "attractor_merge"],
      "generation_mode": "language",
      "chorus_active": false,
      "dream_active": false,
      "reflection_active": false,
      "mutation_scale_modifier": 0.5,
      "field_gain_modifier": 0.7,
      "decay_rate_modifier": 0.9999
    },
    "dream": {
      "description": "Free association, latent recombination. Field energy 0.5 - 2.0.",
      "energy_threshold": 2.0,
      "behaviors": ["dream_synthesis", "harmonic_mutation", "latent_exploration"],
      "generation_mode": "ephemeral",
      "chorus_active": false,
      "dream_active": true,
      "reflection_active": false,
      "mutation_scale_modifier": 1.5,
      "field_gain_modifier": 0.8,
      "decay_rate_modifier": 0.995
    },
    "reflect": {
      "description": "Deliberate recursion, chorus harmonization. Field energy 2.0 - 5.0.",
      "energy_threshold": 5.0,
      "behaviors": ["recursive_attention", "reflective_loop", "chorus_harmonize"],
      "generation_mode": "chorus",
      "chorus_active": true,
      "dream_active": false,
      "reflection_active": true,
      "mutation_scale_modifier": 1.0,
      "field_gain_modifier": 1.0,
      "decay_rate_modifier": 0.995
    },
    "explore": {
      "description": "Novelty seeking, bifurcation, high mutation. Field energy >= 5.0.",
      "energy_threshold": null,
      "behaviors": ["bifurcation", "phase_noise", "high_mutation", "chorus_harmonize"],
      "generation_mode": "chorus",
      "chorus_active": true,
      "dream_active": false,
      "reflection_active": true,
      "mutation_scale_modifier": 2.0,
      "field_gain_modifier": 1.3,
      "decay_rate_modifier": 0.993
    }
  },
  "transitions": {
    "stabilize_to_dream":  "field_energy crosses 0.5 upward",
    "dream_to_reflect":    "field_energy crosses 2.0 upward",
    "reflect_to_explore":  "field_energy crosses 5.0 upward",
    "explore_to_reflect":  "field_energy drops below 5.0",
    "reflect_to_dream":    "field_energy drops below 2.0",
    "dream_to_stabilize":  "field_energy drops below 0.5"
  },
  "emotional_modulation": {
    "curiosity_drives":    ["mutation_scale", "field_gain", "exploration"],
    "wonder_drives":       ["dream_pressure", "mutation_scale"],
    "joy_drives":          ["crystallization", "attractor_pull", "stability"],
    "tension_drives":      ["decay_rate", "coherence_gate"],
    "boredom_drives":      ["dream_pressure", "mutation_scale"],
    "stability_drives":    ["decay_rate", "attractor_pull", "identity_persistence"]
  }
}
